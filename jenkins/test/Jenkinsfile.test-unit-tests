pipeline {
    agent {
        docker {
            label 'shared-x86-centos9'
            image 'registry.access.redhat.com/ubi9/ubi:latest'
            args '-v $HOME/.cache/go-mod:/go/pkg/mod -v $HOME/go:/usr/local/go'
        }
    }
    
    options {
        timestamps()
        timeout(time: 20, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }
    
    environment {
        GO_VERSION = '1.25'
        GOPROXY = 'https://proxy.golang.org,direct'
        GOSUMDB = 'sum.golang.org'
        GOTOOLCHAIN = 'local'
        PATH = "/usr/local/go/bin:${env.PATH}"
    }
    
    stages {
        stage('Checkout') {
            steps {
                echo "=== Checkout repository ==="
                checkout scm
            }
        }
        
        stage('Install Go 1.25') {
            steps {
                echo "=== Install Go ${GO_VERSION} ==="
                sh '''
                    if [ ! -f /usr/local/go/bin/go ]; then
                        echo "Installing Go ${GO_VERSION}..."
                        cd /tmp
                        
                        # Try different version formats and verify download
                        for version_suffix in "" ".0" ".1"; do
                            GO_TARBALL="go${GO_VERSION}${version_suffix}.linux-amd64.tar.gz"
                            GO_URL="https://go.dev/dl/${GO_TARBALL}"
                            
                            echo "Attempting to download: ${GO_URL}"
                            if curl -fsSL -o "${GO_TARBALL}" "${GO_URL}"; then
                                # Verify it's a valid gzip file
                                if gzip -t "${GO_TARBALL}" 2>/dev/null; then
                                    echo "Successfully downloaded and verified ${GO_TARBALL}"
                                    tar -C /usr/local -xzf "${GO_TARBALL}"
                                    rm -f "${GO_TARBALL}"
                                    break
                                else
                                    echo "Downloaded file is not a valid gzip archive, trying next version..."
                                    rm -f "${GO_TARBALL}"
                                fi
                            else
                                echo "Download failed for ${GO_URL}, trying next version..."
                            fi
                        done
                        
                        # Verify installation
                        if [ ! -f /usr/local/go/bin/go ]; then
                            echo "ERROR: Failed to install Go ${GO_VERSION}"
                            exit 1
                        fi
                    else
                        echo "Go is already installed, skipping installation"
                    fi
                    
                    /usr/local/go/bin/go version
                '''
            }
        }
        
        stage('Install dependencies') {
            steps {
                echo "=== Install dependencies ==="
                dir('api') {
                    sh '''
                        export PATH=/usr/local/go/bin:$PATH
                        go version
                        go mod tidy
                    '''
                }
            }
        }
        
        stage('Run unit tests') {
            steps {
                echo "=== Run unit tests ==="
                dir('api') {
                    sh '''
                        export PATH=/usr/local/go/bin:$PATH
                        mkdir -p out
                        go test -coverprofile=out/coverage.out -v ./...
                    '''
                }
            }
        }
        
        stage('Generate HTML coverage report') {
            steps {
                echo "=== Generate HTML coverage report ==="
                dir('api') {
                    sh '''
                        export PATH=/usr/local/go/bin:$PATH
                        go tool cover -html=out/coverage.out -o out/coverage.html
                    '''
                }
            }
        }
        
        stage('Upload coverage report as artifact') {
            steps {
                echo "=== Upload coverage report as artifact ==="
                archiveArtifacts artifacts: 'api/out/coverage.out,api/out/coverage.html',
                                 allowEmptyArchive: false
            }
        }
    }
    
    post {
        always {
            echo "=== Unit Test Pipeline Completed ==="
            echo "Status: ${currentBuild.result ?: 'SUCCESS'}"
        }
        success {
            echo "Unit tests passed!"
        }
        failure {
            echo "Unit tests failed!"
        }
        cleanup {
            cleanWs()
        }
    }
}
