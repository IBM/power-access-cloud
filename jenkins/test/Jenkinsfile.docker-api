@Library('pac-shared-lib') _

pipeline {
    agent {
        docker {
            label 'shared-x86-centos9'
            image 'quay.io/podman/stable:latest'
            args '-v /var/run/docker.sock:/var/run/docker.sock -v $HOME/.local/share/containers:/var/lib/containers --privileged'
        }
    }

    parameters {
        booleanParam(
            name: 'SAVE_IMAGE_TAR',
            defaultValue: false,
            description: 'Save and upload image as tar file (useful for testing)'
        )
    }

    options {
        timestamps()
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    environment {
        REGISTRY    = 'icr.io'
        IMAGE_NAME  = 'power-access-cloud'
        CONTEXT_DIR = './api'
        PLATFORM    = 'linux/amd64'

        TRIVY_SBOM_FILE  = 'trivy.json'
        PARLAY_SBOM_FILE = 'parlay.json'
    }

    stages {
        stage('Checkout') {
            steps {
                echo "=== Checkout repository ==="
                checkout scm
            }
        }

        stage('Set Go Version') {
            steps {
                script {
                    env.GO_VERSION = goVersion()
                    echo "Go version: ${env.GO_VERSION}"
                }
            }
        }

        stage('Setup Podman') {
            steps {
                echo "=== Setup Podman ==="
                sh 'podman version'
            }
        }

        stage('Docker Hub Login') {
            steps {
                echo "=== Authenticate to Docker Hub ==="
                script {
                    try {
                        withCredentials([usernamePassword(
                            credentialsId: 'dockerhub-credentials',
                            usernameVariable: 'DOCKERHUB_USERNAME',
                            passwordVariable: 'DOCKERHUB_PASSWORD'
                        )]) {
                            sh '''
                                echo "${DOCKERHUB_PASSWORD}" | podman login docker.io -u "${DOCKERHUB_USERNAME}" --password-stdin
                                echo "Docker Hub authentication successful"
                            '''
                        }
                    } catch (Exception e) {
                        echo "WARNING: Docker Hub login failed: ${e.message}"
                        echo "Continuing without authentication - may hit rate limits"
                    }
                }
            }
        }

        stage('ICR Registry Login') {
            when {
                allOf {
                    not { changeRequest() }
                    not { expression { params.SAVE_IMAGE_TAR == true } }
                    anyOf {
                        branch 'main'
                        branch pattern: 'release-.*', comparator: 'REGEXP'
                    }
                }
            }
            steps {
                echo "=== Log into registry ${REGISTRY} ==="
                withCredentials([
                    string(credentialsId: 'ICR_USERNAME', variable: 'ICR_USER'),
                    string(credentialsId: 'ICR_APIKEY',   variable: 'ICR_KEY')
                ]) {
                    sh 'echo "${ICR_KEY}" | podman login ${REGISTRY} -u "${ICR_USER}" --password-stdin'
                    echo "Logged into ${REGISTRY}"
                }
            }
        }

        stage('Extract Container metadata') {
            steps {
                echo "=== Extract container metadata ==="
                script {
                    withCredentials([string(credentialsId: 'ICR_NAMESPACE', variable: 'ICR_NS')]) {
                        def tagName = ''
                        if (env.CHANGE_ID) {
                            tagName = "pr-${env.CHANGE_ID}"
                        } else if (env.BRANCH_NAME) {
                            tagName = env.BRANCH_NAME.replaceAll('/', '-')
                        } else {
                            def gitCommit = sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                            tagName = "manual-${gitCommit}"
                        }
                        env.IMAGE_TAG = "${REGISTRY}/${ICR_NS}/api:${tagName}"
                    }
                    echo "Image Tag: ${env.IMAGE_TAG}"
                }
            }
        }

        stage('Build Container image') {
            steps {
                echo "=== Build container image with Podman ==="
                sh """
                    podman build \\
                        --platform ${PLATFORM} \\
                        --build-arg GO_VERSION=${GO_VERSION} \\
                        -t ${env.IMAGE_TAG} \\
                        ${CONTEXT_DIR}
                """
            }
        }

        stage('Push to ICR') {
            when {
                allOf {
                    not { changeRequest() }
                    not { expression { params.SAVE_IMAGE_TAR == true } }
                    anyOf {
                        branch 'main'
                        branch pattern: 'release-.*', comparator: 'REGEXP'
                    }
                }
            }
            steps {
                echo "=== Push image to ICR registry ==="
                sh """
                    podman push ${env.IMAGE_TAG}
                    echo "Image pushed successfully: ${env.IMAGE_TAG}"
                """
            }
        }

        stage('Save image to tar') {
            when {
                anyOf {
                    changeRequest()
                    expression { params.SAVE_IMAGE_TAR == true }
                }
            }
            steps {
                echo "=== Save image to tar ==="
                sh '''
                    rm -f image.tar
                    podman save "${IMAGE_TAG}" -o image.tar
                '''
            }
        }

        stage('Upload image tar') {
            when {
                anyOf {
                    changeRequest()
                    expression { params.SAVE_IMAGE_TAR == true }
                }
            }
            steps {
                echo "=== Upload image tar ==="
                archiveArtifacts artifacts: 'image.tar', allowEmptyArchive: false
                echo "Image tar archived"
            }
        }

        stage('License Scan') {
            steps {
                script {
                    echo "=== Running license scan ==="
                    def imageSource = (env.CHANGE_ID || params.SAVE_IMAGE_TAR) ? 'image.tar' : env.IMAGE_TAG
                    licenseScan(imageSource: imageSource, trivyFile: env.TRIVY_SBOM_FILE, parlayFile: env.PARLAY_SBOM_FILE)
                }
            }
        }
    }

    post {
        always {
            echo "=== Container Build Pipeline Completed ==="
            echo "Status: ${currentBuild.result ?: 'SUCCESS'}"
            notifyGitHub(currentBuild.result)
        }
        success {
            echo "Container build succeeded!"
        }
        failure {
            echo "Container build failed!"
        }
        cleanup {
            script {
                if (env.IMAGE_TAG) {
                    sh "podman rmi ${env.IMAGE_TAG} || true"
                }
            }
            cleanWs()
        }
    }
}
